### 1. PRODUCTOS
# 1.1. Crear producto 1: Lavandina
POST http://localhost:3000/productos/api
Content-Type: application/json

{
  "codigoSKU": "LAV-1L-UN",
  "nombre": "Lavandina 1L",
  "descripcion": "Lavandina concentrada apta para uso doméstico e institucional",
  "categoria": "Desinfectantes",
  "unidad": "litro",
  "precio": 850,
  "stockMinimo": 50
}

### 1.2. Crear producto 2: Detergente
POST http://localhost:3000/productos/api
Content-Type: application/json

{
  "codigoSKU": "DET-500-UN",
  "nombre": "Detergente 500ml",
  "descripcion": "Detergente líquido concentrado para vajilla",
  "categoria": "Detergentes",
  "unidad": "unidad",
  "precio": 620,
  "stockMinimo": 30
}

### 1.3. Crear producto 3: Escoba
POST http://localhost:3000/productos/api
Content-Type: application/json

{
  "codigoSKU": "ESC-MED-UN",
  "nombre": "Escoba mediana",
  "descripcion": "Escoba de cerdas duras para uso industrial",
  "categoria": "Limpieza dura",
  "unidad": "unidad",
  "precio": 1200,
  "stockMinimo": 10
}

### 1.4. Listar todos los productos
GET http://localhost:3000/productos/api

### 1.5. Filtrar por categoría
GET http://localhost:3000/productos/api?categoria=Desinfectantes

### 1.6. Obtener un producto específico
GET http://localhost:3000/productos/api/1

### 1.7. Actualizar precio
PUT http://localhost:3000/productos/api/1
Content-Type: application/json

{
  "precio": 920
}

### 1.8. ERROR: Intentar crear con SKU duplicado
POST http://localhost:3000/productos/api
Content-Type: application/json

{
  "codigoSKU": "LAV-1L-UN",
  "nombre": "Lavandina copia",
  "categoria": "Desinfectantes",
  "unidad": "litro",
  "precio": 800,
  "stockMinimo": 20
}

### 1.9. ERROR: Intentar crear sin campos obligatorios
POST http://localhost:3000/productos/api
Content-Type: application/json

{
  "nombre": "Producto incompleto"
}


### 2. CLIENTES
# 2.1. Crear cliente 1: Almacén Don Jorge
POST http://localhost:3000/clientes/api
Content-Type: application/json

{
  "nombre": "Almacén Don Jorge",
  "cuit": "20-33445566-7",
  "telefono": "341-555-0101",
  "email": "donjorge@gmail.com",
  "direccion": "Av. Pellegrini 1234, Rosario",
  "condicionIVA": "responsable_inscripto",
  "limiteCredito": 50000,
  "diasPlazo": 30
}

### 2.2. Crear cliente 2: Supermercado El Ahorro
POST http://localhost:3000/clientes/api
Content-Type: application/json

{
  "nombre": "Supermercado El Ahorro",
